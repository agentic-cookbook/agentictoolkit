{
  "name": "@agentic-web-toolkit/reference-web-site",
  "version": "0.1.0",
  "description": "Vite-based reference site template for agentic-web-toolkit (includes Vite plugin for markdown ingestion).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./styles/*.css": "./dist/styles/*.css"
  },
  "scripts": {
    "build": "tsup && pnpm run build:types && pnpm run build:css",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
    "build:css": "node ../../../packaging/copy-css.mjs",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agentic-web-toolkit/controls": "workspace:*",
    "@agentic-web-toolkit/model": "workspace:*",
    "@agentic-web-toolkit/themes": "workspace:*",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "shiki": "^1.24.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/hast": "^3.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild-plugin-preserve-directives": "^0.0.11",
    "jsdom": "^29.0.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "vite": "^5.0.0 || ^6.0.0"
  }
}
