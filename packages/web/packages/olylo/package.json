{
  "name": "@agentic-toolkit/olylo",
  "version": "0.1.0",
  "description": "Expressive olylo logo/face — a persona avatar that blinks, gazes, reacts, and morphs its mouth. Driven by an `expression` prop.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && pnpm run build:types",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.13.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild-plugin-preserve-directives": "^0.0.11",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
