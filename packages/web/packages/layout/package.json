{
  "name": "@agentic-web-toolkit/layout",
  "version": "0.1.0",
  "description": "Header, sidebar, breadcrumbs, TOC, and AppShell layout primitives for agentic-web-toolkit.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./css/*.css": "./dist/css/*.css"
  },
  "scripts": {
    "build": "tsup && pnpm run build:types && pnpm run build:css",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
    "build:css": "node ../../packaging/copy-css.mjs",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agentic-web-toolkit/model": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild-plugin-preserve-directives": "^0.0.11",
    "jsdom": "^29.0.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
